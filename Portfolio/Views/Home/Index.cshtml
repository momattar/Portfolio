@{
    ViewData["Title"] = "Mohamed Ashraf Mattar";
}
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Mohamed Mattar – Software Engineer | Project coordinator</title>
    <link rel="icon" href="/favicon.ico">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Epilogue:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    


    <style>
        /* ═══════════════════════════════════════════
           TOKENS
        ═══════════════════════════════════════════ */
        :root {
          --trans: background-color .35s ease, color .35s ease, border-color .35s ease, box-shadow .35s ease;
        }
        [data-theme="dark"] {
          --bg:       #0b0d12;
          --surface:  #13161e;
          --surface2: #1a1e2a;
          --surface3: #222636;
          --accent:   #4f8ef7;
          --accent2:  #7ec8e3;
          --green:    #5dde8b;
          --text:     #e8ecf4;
          --text2:    #b0bace;
          --muted:    #6e7a96;
          --border:   rgba(255,255,255,.07);
          --shadow:   0 4px 24px rgba(0,0,0,.45);
          --nav-bg:   rgba(11,13,18,.9);
          --card-hover-border: rgba(79,142,247,.32);
        }
        [data-theme="light"] {
          --bg:       #f4f5f8;
          --surface:  #ffffff;
          --surface2: #eef0f5;
          --surface3: #e4e7ef;
          --accent:   #2f6fe8;
          --accent2:  #4aa8c8;
          --green:    #27a85a;
          --text:     #1a1d27;
          --text2:    #3a3f52;
          --muted:    #7a849c;
          --border:   rgba(0,0,0,.09);
          --shadow:   0 4px 24px rgba(0,0,0,.10);
          --nav-bg:   rgba(244,245,248,.92);
          --card-hover-border: rgba(47,111,232,.28);
        }

        /* ═══════════════════════════════════════════
           RESET & BASE
        ═══════════════════════════════════════════ */
        *{margin:0;padding:0;box-sizing:border-box;}
        ::selection{background:var(--accent);color:#fff;}
        html{scroll-behavior:smooth;}
        body{
          font-family:'Epilogue',sans-serif;
          background:var(--bg);color:var(--text);
          overflow-x:hidden;
          transition:var(--trans);
        }
        a{text-decoration:none;color:inherit;}
        img{display:block;max-width:100%;}

        /* noise */
        body::before{
          content:'';position:fixed;inset:0;
          background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.025'/%3E%3C/svg%3E");
          pointer-events:none;z-index:9998;
        }

        /* ═══════════════════════════════════════════
           NAV
        ═══════════════════════════════════════════ */
        nav{
          position:fixed;top:0;left:0;right:0;z-index:400;
          display:flex;justify-content:space-between;align-items:center;
          padding:16px 60px;
          background:var(--nav-bg);
          backdrop-filter:blur(20px);
          border-bottom:1px solid var(--border);
          transition:var(--trans);
        }
        .nav-logo{
          font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem;
          color:var(--text);letter-spacing:-.5px;
        }
        .nav-logo span{color:var(--accent);}
        .nav-center{display:flex;gap:30px;list-style:none;}
        .nav-center a{
          font-size:.83rem;font-weight:500;color:var(--muted);
          letter-spacing:.4px;position:relative;
          transition:color .2s;
        }
        .nav-center a::after{
          content:'';position:absolute;bottom:-4px;left:0;
          width:0;height:1.5px;background:var(--accent);transition:width .25s;
        }
        .nav-center a:hover,.nav-center a.active{color:var(--text);}
        .nav-center a:hover::after,.nav-center a.active::after{width:100%;}
        .nav-right{display:flex;align-items:center;gap:12px;}

        /* theme toggle */
        .theme-btn{
          width:36px;height:36px;border-radius:9px;
          background:var(--surface2);border:1px solid var(--border);
          display:flex;align-items:center;justify-content:center;
          color:var(--muted);cursor:pointer;font-size:.9rem;
          transition:var(--trans),transform .2s;
        }
        .theme-btn:hover{color:var(--accent);transform:rotate(20deg);}

        /* admin trigger */
        .admin-trigger{
          width:36px;height:36px;border-radius:9px;
          background:var(--surface2);border:1px solid var(--border);
          display:flex;align-items:center;justify-content:center;
          color:var(--muted);cursor:pointer;font-size:.85rem;
          transition:var(--trans);
        }
        .admin-trigger:hover{color:var(--accent);border-color:var(--card-hover-border);}

        /* mobile hamburger */
        .nav-hamburger{
          display:none;width:36px;height:36px;border-radius:9px;
          background:var(--surface2);border:1px solid var(--border);
          align-items:center;justify-content:center;
          color:var(--muted);cursor:pointer;font-size:1rem;
          transition:var(--trans);
        }
        .mobile-nav{
          display:none;position:fixed;top:65px;left:0;right:0;z-index:399;
          background:var(--nav-bg);backdrop-filter:blur(20px);
          border-bottom:1px solid var(--border);
          padding:16px 24px;
          flex-direction:column;gap:4px;
          transition:var(--trans);
        }
        .mobile-nav a{
          display:block;padding:10px 0;font-size:.9rem;
          color:var(--muted);border-bottom:1px solid var(--border);
          transition:color .2s;
        }
        .mobile-nav a:last-child{border-bottom:none;}
        .mobile-nav a:hover{color:var(--accent);}
        .mobile-nav.open{display:flex;}

        /* ═══════════════════════════════════════════
           HERO
        ═══════════════════════════════════════════ */
        .hero{
          min-height:100vh;
          display:grid;grid-template-columns:1fr 400px;
          align-items:center;gap:72px;
          padding:130px 60px 90px;
          position:relative;overflow:hidden;
        }
        .hero-blob{
          position:absolute;pointer-events:none;border-radius:50%;
          filter:blur(80px);opacity:.55;
        }
        .blob1{width:600px;height:600px;top:-150px;right:-100px;
          background:radial-gradient(circle,rgba(79,142,247,.15),transparent 70%);}
        .blob2{width:400px;height:400px;bottom:-80px;left:10%;
          background:radial-gradient(circle,rgba(126,200,227,.08),transparent 70%);}
        [data-theme="light"] .blob1{opacity:.3;}
        [data-theme="light"] .blob2{opacity:.2;}

        .hero-text{position:relative;z-index:1;}
        .hero-pill{
          display:inline-flex;align-items:center;gap:8px;
          font-size:.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;
          color:var(--accent);
          background:rgba(79,142,247,.1);
          border:1px solid rgba(79,142,247,.22);
          padding:5px 14px;border-radius:100px;margin-bottom:24px;
          animation:fadeUp .5s ease both;
        }
        .hero-pill .dot{
          width:6px;height:6px;background:var(--green);border-radius:50%;
          animation:blink 2s infinite;
        }
        @@keyframes blink{0%,100%{opacity:1;}50%{opacity:.3;}}
        .hero h1{
          font-family:'Syne',sans-serif;
          font-size:clamp(2.4rem,4.5vw,3.8rem);
          font-weight:800;line-height:1.08;letter-spacing:-2px;
          color:var(--text);margin-bottom:8px;
          animation:fadeUp .5s .1s ease both;
        }
        .hero h1 .ac{color:var(--accent);}
        .hero-role{
          font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:600;
          color:var(--muted);margin-bottom:22px;letter-spacing:-.2px;
          animation:fadeUp .5s .15s ease both;
        }
        .hero p{
          font-size:.95rem;line-height:1.8;color:var(--muted);
          max-width:500px;margin-bottom:36px;
          animation:fadeUp .5s .2s ease both;
        }
        .hero-btns{display:flex;gap:12px;flex-wrap:wrap;animation:fadeUp .5s .25s ease both;}
        .hero-stats{
          display:flex;gap:36px;margin-top:44px;
          animation:fadeUp .5s .32s ease both;
          padding-top:36px;border-top:1px solid var(--border);
        }
        .stat-num{
          font-family:'Syne',sans-serif;font-size:1.7rem;font-weight:800;
          color:var(--text);letter-spacing:-1px;
        }
        .stat-num span{color:var(--accent);}
        .stat-lbl{font-size:.72rem;color:var(--muted);margin-top:3px;letter-spacing:.3px;}

        .hero-photo{
          position:relative;z-index:1;
          display:flex;flex-direction:column;align-items:center;
          animation:fadeUp .6s .15s ease both;
        }
        .photo-wrap{position:relative;width:100%;}
        .photo-wrap::before{
          content:'';position:absolute;inset:-2px;
          background:linear-gradient(145deg,var(--accent),var(--accent2) 55%,transparent);
          border-radius:22px;z-index:0;
        }
        .photo-inner{
          position:relative;z-index:1;width:100%;height:420px;
          border-radius:21px;background:var(--surface2);
          overflow:hidden;display:flex;align-items:center;justify-content:center;
        }
        .photo-inner img{width:100%;height:100%;object-fit:cover;object-position:top;}
        .photo-placeholder{display:flex;flex-direction:column;align-items:center;gap:10px;color:var(--muted);}
        .photo-placeholder i{font-size:3rem;color:var(--accent);opacity:.25;}
        .photo-placeholder span{font-size:.78rem;}
        .status-chip{
          margin-top:18px;
          background:var(--surface2);border:1px solid var(--border);
          border-radius:100px;padding:8px 18px;
          display:inline-flex;align-items:center;gap:8px;
          font-size:.74rem;font-weight:600;color:var(--green);
          box-shadow:var(--shadow);
          transition:var(--trans);
        }
        .status-chip::before{
          content:'';width:7px;height:7px;background:var(--green);
          border-radius:50%;animation:blink 2s infinite;
        }

        /* ═══════════════════════════════════════════
           SHARED
        ═══════════════════════════════════════════ */
        .divider{height:1px;background:var(--border);margin:0 60px;transition:var(--trans);}
        .section{padding:90px 60px;max-width:1200px;margin:0 auto;}
        .sec-label{
          font-size:.7rem;font-weight:700;letter-spacing:3px;
          text-transform:uppercase;color:var(--accent);margin-bottom:9px;
        }
        .sec-title{
          font-family:'Syne',sans-serif;
          font-size:clamp(1.7rem,3vw,2.3rem);font-weight:800;
          letter-spacing:-1px;color:var(--text);margin-bottom:10px;
        }
        .sec-sub{font-size:.92rem;color:var(--muted);max-width:480px;line-height:1.75;margin-bottom:48px;}

        /* BTNs */
        .btn-primary{
          display:inline-flex;align-items:center;gap:8px;
          background:var(--accent);color:#fff;
          font-family:'Epilogue',sans-serif;font-weight:600;font-size:.86rem;
          padding:11px 22px;border-radius:8px;border:none;cursor:pointer;
          transition:filter .2s,transform .2s,box-shadow .2s;
          box-shadow:0 4px 20px rgba(79,142,247,.28);
        }
        .btn-primary:hover{filter:brightness(1.12);transform:translateY(-2px);box-shadow:0 8px 28px rgba(79,142,247,.38);}
        .btn-ghost{
          display:inline-flex;align-items:center;gap:8px;
          background:transparent;color:var(--muted);
          font-family:'Epilogue',sans-serif;font-weight:600;font-size:.86rem;
          padding:11px 22px;border-radius:8px;border:1px solid var(--border);cursor:pointer;
          transition:color .2s,border-color .2s,transform .2s;
        }
        .btn-ghost:hover{color:var(--text);border-color:rgba(255,255,255,.2);transform:translateY(-2px);}
        .btn-sm{
          display:inline-flex;align-items:center;gap:6px;
          background:var(--surface2);color:var(--muted);
          font-family:'Epilogue',sans-serif;font-weight:600;font-size:.75rem;
          padding:7px 14px;border-radius:6px;border:1px solid var(--border);cursor:pointer;
          transition:var(--trans);
        }
        .btn-sm:hover{color:var(--accent);border-color:var(--card-hover-border);}
        .btn-danger{background:rgba(239,68,68,.12);color:#ef4444;border-color:rgba(239,68,68,.2);}
        .btn-danger:hover{background:rgba(239,68,68,.2);color:#ef4444;}

        /* ═══════════════════════════════════════════
           ABOUT CARDS
        ═══════════════════════════════════════════ */
        .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
        .about-card{
          background:var(--surface);border:1px solid var(--border);
          border-radius:16px;padding:26px 28px;
          transition:var(--trans),transform .2s;
        }
        .about-card:hover{transform:translateY(-2px);border-color:var(--card-hover-border);}
        .about-card h4{
          font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;
          color:var(--text);margin-bottom:13px;
          display:flex;align-items:center;gap:9px;
        }
        .about-card h4 i{color:var(--accent);font-size:.85rem;}
        .about-card p{font-size:.87rem;color:var(--muted);line-height:1.75;}

        /* ═══════════════════════════════════════════
           STACK
        ═══════════════════════════════════════════ */
        .stack-grid{
          display:grid;
          grid-template-columns:repeat(auto-fill,minmax(190px,1fr));
          gap:13px;
        }
        .stack-item{
          background:var(--surface);border:1px solid var(--border);
          border-radius:12px;padding:16px 18px;
          display:flex;align-items:center;gap:12px;
          transition:var(--trans),transform .2s;
        }
        .stack-item:hover{border-color:var(--card-hover-border);transform:translateY(-3px);}
        .si-icon{
          width:34px;height:34px;border-radius:8px;flex-shrink:0;
          background:rgba(79,142,247,.1);
          display:flex;align-items:center;justify-content:center;
          font-size:.95rem;color:var(--accent);
        }
        .si-name{font-size:.84rem;font-weight:600;color:var(--text);}
        .si-cat{font-size:.68rem;color:var(--muted);margin-top:2px;}

        /* ═══════════════════════════════════════════
           EXPERIENCE TIMELINE
        ═══════════════════════════════════════════ */
        #experience-list{position:relative;padding-left:26px;}
        #experience-list::before{
          content:'';position:absolute;left:0;top:8px;bottom:0;
          width:1.5px;background:var(--border);
        }
        .tl-item{
          position:relative;margin-bottom:40px;
          opacity:0;transform:translateY(20px);
          transition:opacity .5s ease,transform .5s ease;
        }
        .tl-item.visible{opacity:1;transform:translateY(0);}
        .tl-item::before{
          content:'';position:absolute;left:-32px;top:7px;
          width:11px;height:11px;border-radius:50%;
          background:var(--accent);
          box-shadow:0 0 0 3px rgba(79,142,247,.18);
        }
        .tl-head{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap;}
        .tl-company{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;color:var(--text);}
        .tl-role{font-size:.82rem;font-weight:600;color:var(--accent);margin-top:3px;}
        .tl-date{
          font-size:.72rem;font-weight:600;color:var(--muted);
          background:var(--surface2);border:1px solid var(--border);
          padding:3px 11px;border-radius:100px;white-space:nowrap;
          transition:var(--trans);
        }
        .tl-body{margin-top:12px;}
        .tl-body ul{list-style:none;display:flex;flex-direction:column;gap:7px;}
        .tl-body li{font-size:.85rem;color:var(--muted);line-height:1.68;padding-left:16px;position:relative;}
        .tl-body li::before{content:'▸';position:absolute;left:0;color:var(--accent);font-size:.68rem;top:3px;}
        .tl-item-actions{display:flex;gap:8px;margin-top:14px;}

        /* ═══════════════════════════════════════════
           PROJECTS
        ═══════════════════════════════════════════ */
        .projects-grid{
          display:grid;
          grid-template-columns:repeat(auto-fill,minmax(290px,1fr));
          gap:20px;
        }
        .proj-card{
          background:var(--surface);border:1px solid var(--border);
          border-radius:16px;overflow:hidden;
          display:flex;flex-direction:column;
          transition:var(--trans),transform .25s,box-shadow .25s;
        }
        .proj-card:hover{
          transform:translateY(-6px);box-shadow:var(--shadow);
          border-color:var(--card-hover-border);
        }
        .proj-img{
          height:165px;background:var(--surface2);
          display:flex;align-items:center;justify-content:center;
          overflow:hidden;position:relative;
        }
        .proj-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s;}
        .proj-card:hover .proj-img img{transform:scale(1.05);}
        .proj-img::after{
          content:'';position:absolute;bottom:0;left:0;right:0;height:40px;
          background:linear-gradient(to top,var(--surface),transparent);
        }
        .proj-img i{font-size:2.5rem;color:var(--muted);opacity:.18;}
        .proj-body{padding:20px;flex:1;display:flex;flex-direction:column;}
        .proj-tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:11px;}
        .proj-tag{
          font-size:.65rem;font-weight:700;letter-spacing:.8px;text-transform:uppercase;
          color:var(--accent);background:rgba(79,142,247,.1);
          border:1px solid rgba(79,142,247,.17);padding:2px 9px;border-radius:100px;
        }
        .proj-title{
          font-family:'Syne',sans-serif;font-size:1.05rem;font-weight:700;
          color:var(--text);margin-bottom:8px;
        }
        .proj-desc{font-size:.84rem;color:var(--muted);line-height:1.65;flex:1;margin-bottom:16px;}
        .proj-footer{display:flex;align-items:center;justify-content:space-between;}
        .proj-link{
          display:inline-flex;align-items:center;gap:6px;
          font-size:.78rem;font-weight:700;color:var(--accent);
          transition:gap .2s;
        }
        .proj-link:hover{gap:11px;}
        .proj-item-actions{display:flex;gap:7px;}

        /* ═══════════════════════════════════════════
           EDUCATION
        ═══════════════════════════════════════════ */
        .edu-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:18px;}
        .edu-card{
          background:var(--surface);border:1px solid var(--border);
          border-radius:16px;padding:24px 26px;
          transition:var(--trans),transform .2s;
        }
        .edu-card:hover{border-color:var(--card-hover-border);transform:translateY(-3px);}
        .edu-icon{
          width:38px;height:38px;border-radius:9px;
          background:rgba(79,142,247,.1);
          display:flex;align-items:center;justify-content:center;
          font-size:.95rem;color:var(--accent);margin-bottom:14px;
        }
        .edu-name{font-family:'Syne',sans-serif;font-size:.97rem;font-weight:700;color:var(--text);margin-bottom:3px;}
        .edu-org{font-size:.8rem;color:var(--accent);margin-bottom:5px;}
        .edu-date{font-size:.72rem;color:var(--muted);margin-bottom:11px;}
        .edu-desc{font-size:.83rem;color:var(--muted);line-height:1.68;}
        .edu-item-actions{display:flex;gap:7px;margin-top:14px;}

        /* mini cards (certs, volunteering) */
        .mini-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:14px;margin-bottom:44px;}
        .mini-card{
          background:var(--surface);border:1px solid var(--border);
          border-radius:12px;padding:16px 18px;
          display:flex;align-items:flex-start;gap:13px;
          transition:var(--trans),transform .2s;
        }
        .mini-card:hover{border-color:var(--card-hover-border);transform:translateY(-2px);}
        .mini-icon{
          width:32px;height:32px;border-radius:7px;flex-shrink:0;
          background:rgba(79,142,247,.1);
          display:flex;align-items:center;justify-content:center;
          font-size:.85rem;color:var(--accent);
        }
        .mini-title{font-size:.85rem;font-weight:600;color:var(--text);margin-bottom:2px;}
        .mini-sub{font-size:.72rem;color:var(--muted);}

        /* ═══════════════════════════════════════════
           CONTACT
        ═══════════════════════════════════════════ */
        .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start;}
        .contact-info p{font-size:.92rem;color:var(--muted);line-height:1.78;margin-bottom:28px;}
        .social-row{display:flex;gap:11px;}
        .soc-btn{
          width:40px;height:40px;border-radius:9px;
          background:var(--surface2);border:1px solid var(--border);
          display:flex;align-items:center;justify-content:center;
          color:var(--muted);font-size:.95rem;
          transition:var(--trans),transform .2s;
        }
        .soc-btn:hover{background:var(--accent);color:#fff;transform:translateY(-2px);border-color:var(--accent);}

        .contact-form{display:flex;flex-direction:column;gap:14px;}
        .cf-label{font-size:.7rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:5px;display:block;}
        .cf-input{
          width:100%;background:var(--surface);border:1px solid var(--border);
          border-radius:8px;padding:11px 14px;
          color:var(--text);font-family:'Epilogue',sans-serif;font-size:.9rem;
          outline:none;transition:var(--trans);
        }
        .cf-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(79,142,247,.1);}
        textarea.cf-input{resize:vertical;min-height:100px;}
        .cf-success{
          display:none;background:rgba(93,222,139,.1);
          border:1px solid rgba(93,222,139,.25);border-radius:8px;
          padding:13px 16px;font-size:.86rem;color:var(--green);
          align-items:center;gap:9px;
        }
        .cf-success.show{display:flex;}

        /* ═══════════════════════════════════════════
           FOOTER
        ═══════════════════════════════════════════ */
        footer{
          border-top:1px solid var(--border);
          padding:26px 60px;
          display:flex;justify-content:space-between;align-items:center;
          background:var(--nav-bg);transition:var(--trans);
        }
        .footer-copy{font-size:.78rem;color:var(--muted);}
        .footer-copy span{color:var(--accent);}

        /* ═══════════════════════════════════════════
           ADMIN OVERLAY
        ═══════════════════════════════════════════ */
        .admin-overlay{
          position:fixed;inset:0;z-index:800;
          background:rgba(0,0,0,.7);backdrop-filter:blur(6px);
          display:none;align-items:flex-start;justify-content:flex-end;
        }
        .admin-overlay.open{display:flex;}

        .admin-panel{
          width:520px;max-width:95vw;height:100vh;
          background:var(--surface);
          border-left:1px solid var(--border);
          display:flex;flex-direction:column;
          overflow:hidden;
          animation:slideIn .3s ease;
          transition:var(--trans);
        }
        @@keyframes slideIn{from{transform:translateX(100%);}to{transform:translateX(0);}}

        .admin-head{
          padding:22px 26px;border-bottom:1px solid var(--border);
          display:flex;align-items:center;justify-content:space-between;
          flex-shrink:0;
        }
        .admin-head h2{
          font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;
          color:var(--text);
        }
        .admin-close{
          width:32px;height:32px;border-radius:7px;
          background:var(--surface2);border:1px solid var(--border);
          display:flex;align-items:center;justify-content:center;
          color:var(--muted);cursor:pointer;font-size:.9rem;
          transition:var(--trans);
        }
        .admin-close:hover{color:var(--text);}

        /* admin login */
        .admin-login{
          flex:1;display:flex;flex-direction:column;
          align-items:center;justify-content:center;
          padding:40px;gap:16px;
        }
        .admin-login i{font-size:2.5rem;color:var(--accent);opacity:.4;margin-bottom:8px;}
        .admin-login h3{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;color:var(--text);}
        .admin-login p{font-size:.84rem;color:var(--muted);text-align:center;}
        .pw-input{
          width:100%;background:var(--surface2);border:1px solid var(--border);
          border-radius:8px;padding:11px 14px;
          color:var(--text);font-family:'Epilogue',sans-serif;font-size:.9rem;
          outline:none;transition:var(--trans);text-align:center;letter-spacing:3px;
        }
        .pw-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(79,142,247,.1);}
        .pw-error{font-size:.8rem;color:#ef4444;display:none;}
        .pw-error.show{display:block;}

        /* admin tabs */
        .admin-tabs{
          display:flex;border-bottom:1px solid var(--border);
          flex-shrink:0;overflow-x:auto;
        }
        .admin-tab{
          padding:12px 18px;font-size:.78rem;font-weight:700;
          letter-spacing:.5px;text-transform:uppercase;color:var(--muted);
          cursor:pointer;border-bottom:2px solid transparent;
          white-space:nowrap;transition:color .2s,border-color .2s;
        }
        .admin-tab.active{color:var(--accent);border-bottom-color:var(--accent);}
        .admin-tab:hover{color:var(--text);}

        .admin-body{flex:1;overflow-y:auto;padding:24px;}

        /* admin list items */
        .admin-list{display:flex;flex-direction:column;gap:10px;margin-bottom:20px;}
        .admin-list-item{
          background:var(--surface2);border:1px solid var(--border);
          border-radius:10px;padding:14px 16px;
          display:flex;justify-content:space-between;align-items:center;gap:12px;
          transition:var(--trans);
        }
        .admin-list-item:hover{border-color:var(--card-hover-border);}
        .ali-info{}
        .ali-name{font-size:.88rem;font-weight:600;color:var(--text);}
        .ali-sub{font-size:.74rem;color:var(--muted);margin-top:2px;}
        .ali-actions{display:flex;gap:7px;flex-shrink:0;}

        /* admin form */
        .admin-form{
          background:var(--surface2);border:1px solid var(--border);
          border-radius:12px;padding:20px;
          display:none;flex-direction:column;gap:13px;
          margin-bottom:16px;
        }
        .admin-form.open{display:flex;}
        .admin-form h4{font-family:'Syne',sans-serif;font-size:.9rem;font-weight:700;color:var(--text);}
        .af-label{font-size:.7rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:4px;display:block;}
        .af-input{
          width:100%;background:var(--surface);border:1px solid var(--border);
          border-radius:7px;padding:10px 13px;
          color:var(--text);font-family:'Epilogue',sans-serif;font-size:.87rem;
          outline:none;transition:var(--trans);
        }
        .af-input:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(79,142,247,.1);}
        textarea.af-input{resize:vertical;min-height:80px;}
        .af-row{display:flex;gap:10px;}
        .af-row>div{flex:1;}
        .af-actions{display:flex;gap:9px;justify-content:flex-end;margin-top:4px;}

        /* loading spinner */
        .spinner{
          width:20px;height:20px;border:2px solid var(--border);
          border-top-color:var(--accent);border-radius:50%;
          animation:spin .7s linear infinite;display:inline-block;
        }
        @@keyframes spin{to{transform:rotate(360deg);}}

        /* toast */
        .toast{
          position:fixed;bottom:28px;right:28px;z-index:900;
          background:var(--surface);border:1px solid var(--border);
          border-radius:10px;padding:13px 18px;
          display:flex;align-items:center;gap:10px;
          font-size:.84rem;color:var(--text);
          box-shadow:var(--shadow);
          transform:translateY(20px);opacity:0;
          transition:transform .3s ease,opacity .3s ease;
          pointer-events:none;
        }
        .toast.show{transform:translateY(0);opacity:1;}
        .toast.success .toast-icon{color:var(--green);}
        .toast.error .toast-icon{color:#ef4444;}

        /* ═══════════════════════════════════════════
           ANIMATIONS
        ═══════════════════════════════════════════ */
        @@keyframes fadeUp{from{opacity:0;transform:translateY(22px);}to{opacity:1;transform:translateY(0);}}
        .reveal{opacity:0;transform:translateY(28px);transition:opacity .55s ease,transform .55s ease;}
        .reveal.visible{opacity:1;transform:translateY(0);}

        /* ═══════════════════════════════════════════
           RESPONSIVE
        ═══════════════════════════════════════════ */
        @@media(max-width:960px){
          nav{padding:14px 24px;}
          .nav-center{display:none;}
          .nav-hamburger{display:flex;}
          .hero{grid-template-columns:1fr;padding:100px 24px 70px;gap:44px;}
          .hero-photo{order:-1;}
          .photo-inner{height:300px;max-width:260px;margin:0 auto;}
          .status-chip{display:none;}
          .section{padding:72px 24px;}
          .divider{margin:0 24px;}
          .about-grid{grid-template-columns:1fr;}
          .contact-grid{grid-template-columns:1fr;gap:40px;}
          footer{padding:22px 24px;flex-direction:column;gap:12px;text-align:center;}
        }
    </style>
</head>
<body>

