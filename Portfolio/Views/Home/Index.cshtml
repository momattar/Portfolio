            await loadSkills();
            await renderAdminSkills(document.getElementById('admin-body'));
          } catch(e) { showToast(e.message,'error'); }
        }

        async function reorderSkill(id, direction){
          try {
            await post('ReorderSkill', { id, direction });
            await loadSkills();
            await renderAdminSkills(document.getElementById('admin-body'));
          } catch(e) { showToast(e.message,'error'); }
        }

        /* ── ADMIN: CERTIFICATES ── */
                async function renderAdminCertificates(body){
            const data = await get('GetCertificates');
            body.innerHTML = `
                <div id="cert-form" class="admin-form">
                    <h4 id="cert-form-title">Add Certificate</h4>
                    <input type="hidden" id="cert-id">
                    <div><label class="af-label">Title</label><input class="af-input" id="cert-title" placeholder="AWS Certified Developer"></div>
                    <div><label class="af-label">Issuer</label><input class="af-input" id="cert-issuer" placeholder="Amazon Web Services"></div>
                    <div><label class="af-label">Certificate URL (optional)</label><input class="af-input" id="cert-url" placeholder="https://…"></div>
                    <div class="af-actions">
                        <button class="btn-sm" onclick="cancelForm('cert-form')">Cancel</button>
                        <button class="btn-primary" onclick="saveCertificate()" style="font-size:.8rem;padding:8px 16px;">Save</button>
                    </div>
                </div>
                <button class="btn-sm" style="margin-bottom:14px;" onclick="openForm('cert-form','cert-form-title','Add Certificate')">
                    <i class="fas fa-plus"></i> Add Certificate
                </button>
                <div class="admin-list">
                    ${data.map((c,i)=>`
                        <div class="admin-list-item">
                            <div class="ali-info">
                                <div class="ali-name">${c.title}</div>
                                <div class="ali-sub">${c.issuer}</div>
                            </div>
                            <div class="ali-actions">
                                <button class="btn-sm" onclick="reorderCertificate(${c.id},'up')" ${i===0?'disabled':''}><i class="fas fa-arrow-up"></i></button>
                                <button class="btn-sm" onclick="reorderCertificate(${c.id},'down')" ${i===data.length-1?'disabled':''}><i class="fas fa-arrow-down"></i></button>
                                <button class="btn-sm" onclick="editCertificate(${c.id})"><i class="fas fa-pen"></i></button>
                                <button class="btn-sm btn-danger" onclick="deleteCertificate(${c.id})"><i class="fas fa-trash"></i></button>
                            </div>
                        </div>`).join('')}
                </div>`;
        }

        async function saveCertificate(){
            const id = document.getElementById('cert-id').value;
            const body = {
                id: id ? +id : 0,
                title: document.getElementById('cert-title').value,
                issuer: document.getElementById('cert-issuer').value,
                url: document.getElementById('cert-url').value
            };
            try {
                if(id) await post('UpdateCertificate', body);
                else await post('CreateCertificate', body);
                showToast(id ? 'Certificate updated!' : 'Certificate added!');
                cancelForm('cert-form');
                await loadCertificates();
                await renderAdminCertificates(document.getElementById('admin-body'));
            } catch(e) { showToast(e.message,'error'); }
        }

        async function editCertificate(id){
            const data = await getOne('GetCertificate', id);
            document.getElementById('cert-id').value = id;
            document.getElementById('cert-title').value = data.title;
            document.getElementById('cert-issuer').value = data.issuer;
            document.getElementById('cert-url').value = data.url||'';
            openForm('cert-form','cert-form-title','Edit Certificate');
        }

        async function deleteCertificate(id){
            if(!confirm('Delete this certificate?')) return;
            try {
                await del('DeleteCertificate', id);
                showToast('Certificate deleted');
                await loadCertificates();
                await renderAdminCertificates(document.getElementById('admin-body'));
            } catch(e) { showToast(e.message,'error'); }
        }

        async function reorderCertificate(id, direction){
          try {
            await post('ReorderCertificate', { id, direction });
            await loadCertificates();
            await renderAdminCertificates(document.getElementById('admin-body'));
          } catch(e) { showToast(e.message,'error'); }
        }

        /// ── ADMIN: SETTINGS ──
                async function renderAdminSettings(body){
            const data = await get('GetCvUrl');
            body.innerHTML = `
                <div class="admin-form open" style="margin-top:0;">
                    <h4>CV / Resume Link</h4>
                    <div>
                        <label class="af-label">Google Drive or direct download URL</label>
                        <input class="af-input" id="cv-url-input" value="${data.url}" placeholder="https://drive.google.com/…">
                    </div>
                    <div class="af-actions">
                        <button class="btn-primary" onclick="saveCvUrl()" style="font-size:.8rem;padding:8px 16px;">
                            <i class="fas fa-save"></i> Save
                        </button>
                    </div>
                </div>
                <div class="admin-form open" style="margin-top:20px;">
                    <h4>Display Order Management</h4>
                    <p style="font-size:.85rem;color:var(--muted);margin-bottom:12px;">
                        If reordering buttons aren't working, click below to initialize the display order for all items.
                    </p>
                    <div class="af-actions">
                        <button class="btn-primary" onclick="initializeDisplayOrders()" style="font-size:.8rem;padding:8px 16px;">
                            <i class="fas fa-sort"></i> Initialize Display Orders
                        </button>
                    </div>
                </div>`;
        }

        async function saveCvUrl(){
            try {
                await post('UpdateCvUrl', { url: document.getElementById('cv-url-input').value });
                showToast('CV link updated!');
                await loadCvUrl();
            } catch(e) { showToast(e.message,'error'); }
        }

        async function initializeDisplayOrders(){
            if(!confirm('This will reset the display order of all items. Continue?')) return;
            try {
                await post('InitializeDisplayOrders', {});
                showToast('Display orders initialized!');
                // Reload all data
                await Promise.all([loadProjects(), loadSkills(), loadEducation(), loadCertificates()]);
            } catch(e) { showToast(e.message,'error'); }
        }

        /* ── FORM HELPERS ── */
        function openForm(formId, titleId, title){
          document.getElementById(formId).classList.add('open');
          document.getElementById(titleId).textContent = title;
        }
        function cancelForm(formId){
          const f = document.getElementById(formId);
          f.classList.remove('open');
          f.querySelectorAll('input,textarea').forEach(i => { if(i.type!=='hidden') i.value=''; });
          f.querySelector('input[type=hidden]').value = '';
        }

        /* ── INIT ── */
        (async () => {
            await Promise.all([loadProjects(), loadSkills(), loadExperience(), loadEducation(), loadCertificates(), loadCvUrl()]);
        })();
                if(new URLSearchParams(window.location.search).get('admin') === '1'){
          openAdmin();
        }
    </script>
</body>
</html>
