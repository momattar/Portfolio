    <!-- ══════════════════════════════════
       JAVASCRIPT
    ══════════════════════════════════ -->
    <script>
                /* ── ADMIN PASSWORD ── */
        let adminUnlocked = false;
        let currentTab = 'projects';

        /* ── THEME ── */
        (function(){
          const saved = localStorage.getItem('theme') || 'dark';
          setTheme(saved, false);
        })();
        function setTheme(t, save=true){
          document.documentElement.setAttribute('data-theme', t);
          document.getElementById('theme-icon').className = t==='dark' ? 'fas fa-sun' : 'fas fa-moon';
          if(save) localStorage.setItem('theme', t);
        }
        function toggleTheme(){
          setTheme(document.documentElement.getAttribute('data-theme')==='dark' ? 'light' : 'dark');
        }

        /* ── MOBILE NAV ── */
        function toggleMobileNav(){ document.getElementById('mobile-nav').classList.toggle('open'); }
        function closeMobileNav(){ document.getElementById('mobile-nav').classList.remove('open'); }

        /* ── SCROLL REVEAL ── */
        const revealObs = new IntersectionObserver(entries => {
          entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
        }, {threshold: 0.08});
        document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

        /* ── NAV ACTIVE ── */
        window.addEventListener('scroll', () => {
          const secs = ['home','about','experience','projects','education','contact'];
          let cur = '';
          secs.forEach(id => {
            const el = document.getElementById(id);
            if(el && window.scrollY >= el.offsetTop - 130) cur = id;
          });
          document.querySelectorAll('.nav-center a').forEach(a => {
            a.classList.toggle('active', a.getAttribute('href').replace('#','') === cur);
          });
        });

        /* ── TOAST ── */
        function showToast(msg, type='success'){
          const t = document.getElementById('toast');
          document.getElementById('toast-msg').textContent = msg;
          t.className = `toast ${type}`;
          t.querySelector('.toast-icon').className = `toast-icon fas fa-${type==='success'?'check-circle':'exclamation-circle'}`;
          t.classList.add('show');
          setTimeout(() => t.classList.remove('show'), 3000);
        }

        /* ── FETCH HELPER ──
           GET  → fetch(url)                          → /Home/GetProjects
           GET1 → fetch(url + '?id=X')               → /Home/GetProject?id=5
           POST → fetch(url, body)                   → /Home/CreateProject
           PUT  → fetch(url, body) with id in body   → /Home/UpdateProject
           DEL  → fetch(url + '?id=X', {del:true})   → /Home/DeleteProject?id=5
        */
        async function get(action) {
          const r = await fetch(`/Home/${action}`);
          if(!r.ok) throw new Error(`${action} failed: ${r.status}`);
          return r.json();
        }
        async function getOne(action, id) {
          const r = await fetch(`/Home/${action}?id=${id}`);
          if(!r.ok) throw new Error(`${action} failed: ${r.status}`);
          return r.json();
        }
        async function post(action, body) {
          const r = await fetch(`/Home/${action}`, {
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body: JSON.stringify(body)
          });
          if(!r.ok) throw new Error(`${action} failed: ${r.status}`);
          const text = await r.text();
          return text ? JSON.parse(text) : null;
        }
        async function del(action, id) {
          const r = await fetch(`/Home/${action}?id=${id}`, { method:'POST' });
          if(!r.ok) throw new Error(`${action} failed: ${r.status}`);
          return r.json();
        }

        /* ── LOAD DATA ── */
        async function loadProjects(){
          try {
            const data = await get('GetProjects');
            document.getElementById('projects-grid').innerHTML = data.length ? data.map(p => `
              <div class="proj-card">
                <div class="proj-img">
                  ${p.imagePath ? `<img src="${p.imagePath}" alt="${p.title}">` : `<i class="fas fa-code"></i>`}
                </div>
                <div class="proj-body">
                  <div class="proj-tags">
                    ${(p.techStack||'').split(',').filter(Boolean).map(t=>`<span class="proj-tag">${t.trim()}</span>`).join('')}
                  </div>
                  <div class="proj-title">${p.title}</div>
